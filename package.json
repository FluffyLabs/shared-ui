{
  "name": "@fluffylabs/shared-ui",
  "version": "0.8.0",
  "description": "Components library for Fluffy Labs projects",
  "author": "Fluffy Labs <hello@fluffylabs.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/FluffyLabs/shared-ui"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "./dist/global.css"
  ],
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.es.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs.js"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/*.d.ts",
        "default": "./dist/*.es.js"
      },
      "require": {
        "types": "./dist/*.d.ts",
        "default": "./dist/*.cjs.js"
      }
    },
    "./components": {
      "import": {
        "types": "./dist/components/index.d.ts",
        "default": "./dist/components/index.es.js"
      },
      "require": {
        "types": "./dist/components/index.d.ts",
        "default": "./dist/components/index.cjs.js"
      }
    },
    "./ui": {
      "import": {
        "types": "./dist/ui/index.d.ts",
        "default": "./dist/ui/index.es.js"
      },
      "require": {
        "types": "./dist/ui/index.d.ts",
        "default": "./dist/ui/index.cjs.js"
      }
    },
    "./hooks": {
      "import": {
        "types": "./dist/hooks.d.ts",
        "default": "./dist/hooks.es.js"
      },
      "require": {
        "types": "./dist/hooks.d.ts",
        "default": "./dist/hooks.cjs.js"
      }
    },
    "./utils": {
      "import": {
        "types": "./dist/utils.d.ts",
        "default": "./dist/utils.es.js"
      },
      "require": {
        "types": "./dist/utils.d.ts",
        "default": "./dist/utils.cjs.js"
      }
    },
    "./supabase": {
      "import": {
        "types": "./dist/supabase/index.d.ts",
        "default": "./dist/supabase/index.es.js"
      },
      "require": {
        "types": "./dist/supabase/index.d.ts",
        "default": "./dist/supabase/index.cjs.js"
      }
    },
    "./style.css": "./dist/style.css",
    "./theme.css": "./dist/theme.css"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run build:storybook && npm run build:demo",
    "build:storybook": "storybook build",
    "build:demo": "vite build --config demo/vite.config.ts",
    "build:lib": "rm -rf dist && vite build && cp ./lib/theme.css ./dist/theme.css",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "format": "prettier . --write",
    "prepare": "echo \"npx --no -- commitlint --edit \\$1\" > .husky/commit-msg"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.0.0",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/builder-vite": "^10.3.1",
    "@storybook/react": "^10.3.1",
    "@storybook/react-vite": "^10.3.1",
    "@supabase/supabase-js": "^2.100.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.0",
    "clsx": "^2.1.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "10.3.1",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.3.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.1.0"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    }
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "commitlint": "^20.5.0",
    "lucide-react": "^0.577.0",
    "tw-animate-css": "^1.4.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix --report-unused-disable-directives --max-warnings 0 --no-warn-ignored",
    "*.{md,json,yml,yaml,js,jsx,ts,tsx}": "prettier --write"
  }
}
